# API runtime
NODE_ENV=development
PORT=3000
DATA_STORE=postgres
DATABASE_URL=postgresql://pockettrainer_app:change-me@localhost:5432/pockettrainer
DATABASE_SSL=false
DATABASE_POOL_MAX=10
REQUEST_BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:8081
OUTBOX_POLL_MS=30000

# Supabase Auth only. Product data must never be written to Supabase Postgres.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Public content origin (Cloudflare R2 custom domain or CDN hostname)
CONTENT_BASE_URL=https://content.pockettrainer.example

# Development-only local token bypass. Never enable outside local development.
ALLOW_INSECURE_DEV_AUTH=false
DEV_AUTH_SUBJECT=00000000-0000-4000-8000-000000000001
