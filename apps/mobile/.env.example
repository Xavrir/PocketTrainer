# Public mobile configuration only. Never place a service-role key here.
POCKETTRAINER_SUPABASE_URL=https://your-project.supabase.co
POCKETTRAINER_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Explicit Android emulator development default. A release build visibly rejects
# localhost, private-network, plain HTTP, and *.trycloudflare.com API origins.
POCKETTRAINER_API_BASE_URL=http://10.0.2.2:3000
# Release example after Azure provisioning:
# POCKETTRAINER_API_BASE_URL=https://pockettrainer-api.<environment>.<region>.azurecontainerapps.io

# Debug-only escape hatch for UI demos. Keep false for release builds.
POCKETTRAINER_ALLOW_AUTH_BYPASS=false
